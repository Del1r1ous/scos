    def __init__(self, node_id):
        # 1. Genesis Block Generation
        self.genesis = GenesisGenerator().generate()
        
        # 2. PUF-Based Fingerprint
        self.puf = PUFSimulator()
        self.fingerprint = FingerprintGenerator(self.puf).generate()
        
        # 3. Witness Protocol
        self.witness = WitnessProtocol(self.genesis, self.fingerprint)
        
        # 4. Consensus Engine
        self.consensus = ConsensusEngine(self.genesis)
        
